\newlabel{tab:optiver-main}{{2}{12}{Optiver 5-event horizon: mean metrics across held-out stocks 42, 17, 82 (\texttt {rolling3} labels).\relax }{table.caption.18}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Per-stock metrics for the 5-event horizon (\texttt  {rolling3}, stocks 42/17/82).\relax }}{13}{table.caption.19}}
\newlabel{tab:optiver-per-stock}{{3}{13}{Per-stock metrics for the 5-event horizon (\texttt {rolling3}, stocks 42/17/82).\relax }{table.caption.19}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Why Rolling-Quantile Labels and Fine-Tuning Work}{13}{subsection.7.4}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Per-stock accuracy and $\kappa $ before and after fine-tuning (\texttt  {rolling3}, stocks 42/17/82). Fine-tuning consistently improves $\kappa $ even when raw accuracy decreases slightly---the classifier redistributes predictions away from the dominant class toward better agreement with the true label distribution.\relax }}{14}{figure.caption.20}}
\newlabel{fig:optiver-transfer-acc}{{11}{14}{Per-stock accuracy and $\kappa $ before and after fine-tuning (\texttt {rolling3}, stocks 42/17/82). Fine-tuning consistently improves $\kappa $ even when raw accuracy decreases slightly---the classifier redistributes predictions away from the dominant class toward better agreement with the true label distribution.\relax }{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Cumulative-profit diagnostics for \texttt  {rolling3} over held-out stocks 42, 17, 82. Fine-tuned predictions (solid lines) accumulate higher proxy profits than zero-shot predictions (dashed) over most held-out periods, providing secondary evidence that the $\kappa $ improvement from fine-tuning has directional value.\relax }}{14}{figure.caption.21}}
\newlabel{fig:optiver-cum-profit}{{12}{14}{Cumulative-profit diagnostics for \texttt {rolling3} over held-out stocks 42, 17, 82. Fine-tuned predictions (solid lines) accumulate higher proxy profits than zero-shot predictions (dashed) over most held-out periods, providing secondary evidence that the $\kappa $ improvement from fine-tuning has directional value.\relax }{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Comparison of three evaluation regimes (\texttt  {rolling3}, stocks 42/17/82, $k{=}5$). Fine-tuning consistently improves $\kappa $ over the zero-shot baseline; specific-stock OOS training collapses to near-zero $\kappa $, confirming that within-stock temporal drift is the harder challenge.\relax }}{15}{figure.caption.22}}
\newlabel{fig:optiver-regimes}{{13}{15}{Comparison of three evaluation regimes (\texttt {rolling3}, stocks 42/17/82, $k{=}5$). Fine-tuning consistently improves $\kappa $ over the zero-shot baseline; specific-stock OOS training collapses to near-zero $\kappa $, confirming that within-stock temporal drift is the harder challenge.\relax }{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}LIME Interpretability Analysis (Optiver)}{15}{subsection.7.5}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces LIME feature-importance explanation for a \emph  {Stationary} prediction on stock\nobreakspace  {}82 ($k{=}5$, sample\nobreakspace  {}731). Bar lengths indicate the magnitude of each input feature's local contribution to the predicted class; color indicates direction (positive = supports predicted class). Features corresponding to recent ask/bid price levels dominate the explanation, consistent with the microstructure intuition that short-term price position relative to recent quotes is the strongest signal in a 2-level LOB.\relax }}{16}{figure.caption.23}}
\newlabel{fig:optiver-lime}{{14}{16}{LIME feature-importance explanation for a \emph {Stationary} prediction on stock~82 ($k{=}5$, sample~731). Bar lengths indicate the magnitude of each input feature's local contribution to the predicted class; color indicates direction (positive = supports predicted class). Features corresponding to recent ask/bid price levels dominate the explanation, consistent with the microstructure intuition that short-term price position relative to recent quotes is the strongest signal in a 2-level LOB.\relax }{figure.caption.23}{}}
