\newlabel{tab:fi-main}{{1}{6}{DeepLOB performance on FI-2010: paper profile (primary) vs adaptive profile (comparison).\relax }{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Confusion matrices at the 10-event horizon highlight the key contrast: the paper profile predicts up/down classes much more aggressively (fewer false-stationary errors), yielding higher accuracy and MCC; the adaptive profile uses macro-F1 monitoring, which partially corrects collapse but sacrifices raw accuracy.\relax }}{7}{figure.caption.4}}
\newlabel{fig:fi-cm-k1}{{1}{7}{Confusion matrices at the 10-event horizon highlight the key contrast: the paper profile predicts up/down classes much more aggressively (fewer false-stationary errors), yielding higher accuracy and MCC; the adaptive profile uses macro-F1 monitoring, which partially corrects collapse but sacrifices raw accuracy.\relax }{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Loss curves at 50 events. Both profiles converge cleanly. The adaptive profile stops earlier due to the tighter regularization schedule, whereas the paper profile trains longer before early-stopping triggers.\relax }}{7}{figure.caption.5}}
\newlabel{fig:fi-loss-k4}{{2}{7}{Loss curves at 50 events. Both profiles converge cleanly. The adaptive profile stops earlier due to the tighter regularization schedule, whereas the paper profile trains longer before early-stopping triggers.\relax }{figure.caption.5}{}}
