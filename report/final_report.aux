\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Why Rolling-Quantile Labels and Fine-Tuning Work}{9}{subsection.7.4}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Per-stock accuracy and $\kappa $ before and after fine-tuning (\texttt  {rolling3}, stocks 42/17/82). Fine-tuning consistently improves $\kappa $ even when raw accuracy decreases slightly---the classifier redistributes predictions away from the dominant class toward better agreement with the true label distribution.\relax }}{10}{figure.caption.10}}
\newlabel{fig:optiver-transfer-acc}{{5}{10}{Per-stock accuracy and $\kappa $ before and after fine-tuning (\texttt {rolling3}, stocks 42/17/82). Fine-tuning consistently improves $\kappa $ even when raw accuracy decreases slightly---the classifier redistributes predictions away from the dominant class toward better agreement with the true label distribution.\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Cumulative-profit diagnostics for \texttt  {rolling3} over held-out stocks 42, 17, 82. Fine-tuned predictions (solid lines) accumulate higher proxy profits than zero-shot predictions (dashed) over most held-out periods, providing secondary evidence that the $\kappa $ improvement from fine-tuning has directional value.\relax }}{10}{figure.caption.11}}
\newlabel{fig:optiver-cum-profit}{{6}{10}{Cumulative-profit diagnostics for \texttt {rolling3} over held-out stocks 42, 17, 82. Fine-tuned predictions (solid lines) accumulate higher proxy profits than zero-shot predictions (dashed) over most held-out periods, providing secondary evidence that the $\kappa $ improvement from fine-tuning has directional value.\relax }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Comparison of three evaluation regimes (\texttt  {rolling3}, stocks 42/17/82, $k{=}5$). Fine-tuning consistently improves $\kappa $ over the zero-shot baseline; specific-stock OOS training collapses to near-zero $\kappa $, confirming that within-stock temporal drift is the harder challenge.\relax }}{11}{figure.caption.12}}
\newlabel{fig:optiver-regimes}{{7}{11}{Comparison of three evaluation regimes (\texttt {rolling3}, stocks 42/17/82, $k{=}5$). Fine-tuning consistently improves $\kappa $ over the zero-shot baseline; specific-stock OOS training collapses to near-zero $\kappa $, confirming that within-stock temporal drift is the harder challenge.\relax }{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}LIME Interpretability Analysis (Optiver)}{11}{subsection.7.5}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces LIME feature-importance explanation for a \emph  {Stationary} prediction on stock\nobreakspace  {}82 ($k{=}5$, sample\nobreakspace  {}731). Bar lengths indicate the magnitude of each input feature's local contribution to the predicted class; color indicates direction (positive = supports predicted class). Features corresponding to recent ask/bid price levels dominate the explanation, consistent with the microstructure intuition that short-term price position relative to recent quotes is the strongest signal in a 2-level LOB.\relax }}{12}{figure.caption.13}}
\newlabel{fig:optiver-lime}{{8}{12}{LIME feature-importance explanation for a \emph {Stationary} prediction on stock~82 ($k{=}5$, sample~731). Bar lengths indicate the magnitude of each input feature's local contribution to the predicted class; color indicates direction (positive = supports predicted class). Features corresponding to recent ask/bid price levels dominate the explanation, consistent with the microstructure intuition that short-term price position relative to recent quotes is the strongest signal in a 2-level LOB.\relax }{figure.caption.13}{}}
